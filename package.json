{
  "name": "unix-timestamp-converter-extension",
  "version": "1.0.2",
  "description": "A modern Unix timestamp converter extension for Microsoft Edge browser with timezone support",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "vite",
    "dev:watch": "vite build --watch --mode development",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type-check": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  },
  "keywords": [
    "timestamp",
    "converter",
    "unix",
    "edge",
    "extension",
    "timezone",
    "react",
    "typescript"
  ],
  "author": "Developer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StudentWeis/timestamp-converter"
  },
  "bugs": {
    "url": "https://github.com/StudentWeis/timestamp-converter/issues"
  },
  "homepage": "https://github.com/StudentWeis/timestamp-converter#readme"
}
